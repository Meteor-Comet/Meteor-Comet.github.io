---
import type { MarkdownHeading } from "astro";
import { siteConfig } from "../../config";
import { url } from "../../utils/url-utils";

interface Props {
	class?: string;
	headings: MarkdownHeading[];
}

let { headings = [] } = Astro.props;

// Filter out H1 (document title) and "目录" / "Table of Contents" heading
let filteredHeadings = headings.filter((h) => {
	if (h.depth === 1) return false;
	const txt = h.text.trim().toLowerCase();
	if (txt === "目录" || txt === "table of contents") return false;
	return true;
});

let minDepth = 10;
for (const heading of filteredHeadings) {
	minDepth = Math.min(minDepth, heading.depth);
}

const className = Astro.props.class;
const isPostsRoute = Astro.url.pathname.startsWith(url("/posts/"));

const removeTailingHash = (text: string) => {
	let lastIndexOfHash = text.lastIndexOf("#");
	if (lastIndexOfHash !== text.length - 1) {
		return text;
	}
	return text.substring(0, lastIndexOfHash);
};

interface TocGroup {
	parent: MarkdownHeading;
	parentIndex: number;
	badgeNum: number;
	children: { heading: MarkdownHeading; index: number }[];
}

const groups: TocGroup[] = [];
let currentGroup: TocGroup | null = null;
let mainIndex = 1;
let globalHeadingIdx = 0;

for (const heading of filteredHeadings) {
	if (heading.depth === minDepth) {
		currentGroup = {
			parent: heading,
			parentIndex: globalHeadingIdx,
			badgeNum: mainIndex++,
			children: [],
		};
		groups.push(currentGroup);
	} else if (currentGroup && heading.depth > minDepth) {
		currentGroup.children.push({
			heading: heading,
			index: globalHeadingIdx,
		});
	}
	globalHeadingIdx++;
}
---

{isPostsRoute && (
<table-of-contents class:list={[className, "group flex flex-col gap-1 w-full relative"]}>
    {groups.map((group) => {
        const hasChildren = group.children.length > 0;
        return (
            <div class="toc-group-wrapper flex flex-col w-full mb-1">
                <div class="flex items-center justify-between w-full">
                    <a href={`#${group.parent.slug}`}
                       data-idx={group.parentIndex}
                       class="px-2 flex gap-2 relative transition w-full min-h-8 rounded-lg items-center hover:bg-[var(--toc-btn-hover)] active:bg-[var(--toc-btn-active)] py-1.5"
                    >
                        <div class="transition w-5 h-5 shrink-0 rounded-lg text-xs flex items-center justify-center font-bold bg-[var(--toc-badge-bg)] text-[var(--btn-content)]">
                            {group.badgeNum}
                        </div>
                        <div class="transition text-sm font-medium text-75 truncate">
                            {removeTailingHash(group.parent.text)}
                        </div>
                    </a>
                    {hasChildren && (
                        <button type="button"
                                aria-label="Toggle section"
                                class="toc-toggle-btn p-1 ml-1 rounded-md text-neutral-400 hover:text-neutral-700 dark:hover:text-neutral-200 hover:bg-[var(--toc-btn-hover)] transition-all shrink-0"
                        >
                            <svg class="w-3.5 h-3.5 transform transition-transform duration-200 icon-chevron rotate-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                            </svg>
                        </button>
                    )}
                </div>
                {hasChildren && (
                    <div class="toc-children flex flex-col pl-3 border-l-2 border-neutral-200/80 dark:border-neutral-700/80 ml-4.5 my-1 gap-0.5 transition-all duration-300 overflow-hidden">
                        {group.children.map((child) => (
                            <a href={`#${child.heading.slug}`}
                               data-idx={child.index}
                               class="px-2 flex gap-2 relative transition w-full min-h-7 rounded-md items-center hover:bg-[var(--toc-btn-hover)] active:bg-[var(--toc-btn-active)] py-1"
                            >
                                <div class="w-1.5 h-1.5 shrink-0 rounded-full bg-neutral-400/60 dark:bg-neutral-500/60"></div>
                                <div class="transition text-xs text-60 truncate">
                                    {removeTailingHash(child.heading.text)}
                                </div>
                            </a>
                        ))}
                    </div>
                )}
            </div>
        );
    })}
    <div id="active-indicator" style="opacity: 0" class:list={[{'hidden': filteredHeadings.length == 0}, "-z-10 absolute bg-[var(--toc-btn-hover)] left-0 right-0 rounded-xl transition-all group-hover:bg-transparent border-2 border-[var(--toc-btn-hover)] group-hover:border-[var(--toc-btn-active)] border-dashed"]}></div>
</table-of-contents>
)}

<script>
class TableOfContents extends HTMLElement {
    tocEl: HTMLElement | null = null;
    visibleClass = "visible";
    observer: IntersectionObserver;
    anchorNavTarget: HTMLElement | null = null;
    headingIdxMap = new Map<string, number>();
    headings: HTMLElement[] = [];
    sections: HTMLElement[] = [];
    tocEntries: HTMLAnchorElement[] = [];
    active: boolean[] = [];
    activeIndicator: HTMLElement | null = null;

    constructor() {
        super();
        this.observer = new IntersectionObserver(
            this.markVisibleSection, { threshold: 0 }
        );
    }

    markVisibleSection = (entries: IntersectionObserverEntry[]) => {
        entries.forEach((entry) => {
            const id = entry.target.children[0]?.getAttribute("id");
            const idx = id ? this.headingIdxMap.get(id) : undefined;
            if (idx != undefined)
                this.active[idx] = entry.isIntersecting;

            if (entry.isIntersecting && this.anchorNavTarget == entry.target.firstChild)
                this.anchorNavTarget = null;
        });

        if (!this.active.includes(true))
            this.fallback();
        this.update();
    };

    toggleActiveHeading = () => {
        let i = this.active.length - 1;
        let min = this.active.length - 1, max = -1;
        while (i >= 0 && !this.active[i]) {
            if (this.tocEntries[i]) this.tocEntries[i].classList.remove(this.visibleClass);
            i--;
        }
        while (i >= 0 && this.active[i]) {
            if (this.tocEntries[i]) {
                this.tocEntries[i].classList.add(this.visibleClass);
                // Ensure parent .toc-children is visible if an active item is inside it
                const childrenContainer = this.tocEntries[i].closest('.toc-children');
                if (childrenContainer && childrenContainer.classList.contains('hidden')) {
                    childrenContainer.classList.remove('hidden');
                    const chevron = childrenContainer.parentElement?.querySelector('.icon-chevron');
                    if (chevron) chevron.classList.add('rotate-180');
                }
            }
            min = Math.min(min, i);
            max = Math.max(max, i);
            i--;
        }
        while (i >= 0) {
            if (this.tocEntries[i]) this.tocEntries[i].classList.remove(this.visibleClass);
            i--;
        }
        if (min > max) {
            this.activeIndicator?.setAttribute("style", `opacity: 0`);
        } else {
            let parentOffset = this.tocEl?.getBoundingClientRect().top || 0;
            let scrollOffset = this.tocEl?.scrollTop || 0;
            if (this.tocEntries[min] && this.tocEntries[max]) {
                let top = this.tocEntries[min].getBoundingClientRect().top - parentOffset + scrollOffset;
                let bottom = this.tocEntries[max].getBoundingClientRect().bottom - parentOffset + scrollOffset;
                this.activeIndicator?.setAttribute("style", `top: ${top}px; height: ${bottom - top}px`);
            }
        }
    };

    scrollToActiveHeading = () => {
        if (this.anchorNavTarget || !this.tocEl) return;
        const activeHeading =
            document.querySelectorAll<HTMLDivElement>(`#toc .${this.visibleClass}`);
        if (!activeHeading.length) return;

        const topmost = activeHeading[0];
        const bottommost = activeHeading[activeHeading.length - 1];
        const tocHeight = this.tocEl.clientHeight;

        let top;
        if (bottommost.getBoundingClientRect().bottom -
            topmost.getBoundingClientRect().top < 0.9 * tocHeight)
            top = topmost.offsetTop - 32;
        else
            top = bottommost.offsetTop - tocHeight * 0.8;

        this.tocEl.scrollTo({
            top,
            left: 0,
            behavior: "smooth",
        });
    };

    update = () => {
        requestAnimationFrame(() => {
            this.toggleActiveHeading();
            this.scrollToActiveHeading();
        });
    };

    fallback = () => {
        if (!this.sections.length) return;

        for (let i = 0; i < this.sections.length; i++) {
            if (!this.sections[i]) continue;
            let offsetTop = this.sections[i].getBoundingClientRect().top;
            let offsetBottom = this.sections[i].getBoundingClientRect().bottom;

            if (this.isInRange(offsetTop, 0, window.innerHeight)
                || this.isInRange(offsetBottom, 0, window.innerHeight)
                || (offsetTop < 0 && offsetBottom > window.innerHeight)) {                    
                this.markActiveHeading(i);
            }
            else if (offsetTop > window.innerHeight) break;
        }
    };

    markActiveHeading = (idx: number)=> {
        this.active[idx] = true;
    };

    handleAnchorClick = (event: Event) => {
        const anchor = event
            .composedPath()
            .find((element) => element instanceof HTMLAnchorElement);

        if (anchor) {
            const id = decodeURIComponent(anchor.hash?.substring(1));
            const idx = this.headingIdxMap.get(id);
            if (idx !== undefined) {
                this.anchorNavTarget = this.headings[idx];
            } else {
                this.anchorNavTarget = null;
            }
        }
    };

    setupCollapsibleToggles() {
        const toggleBtns = this.querySelectorAll<HTMLButtonElement>('.toc-toggle-btn');
        toggleBtns.forEach((btn) => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                const groupWrapper = btn.closest('.toc-group-wrapper');
                const childrenContainer = groupWrapper?.querySelector('.toc-children');
                const chevron = btn.querySelector('.icon-chevron');
                if (childrenContainer) {
                    childrenContainer.classList.toggle('hidden');
                    if (chevron) {
                        chevron.classList.toggle('rotate-180');
                    }
                }
            });
        });

        // Global toggle button support if present in sidebar
        const globalBtn = document.getElementById('toc-global-toggle');
        if (globalBtn) {
            let allCollapsed = false;
            globalBtn.addEventListener('click', () => {
                allCollapsed = !allCollapsed;
                const childrenContainers = this.querySelectorAll('.toc-children');
                const chevrons = this.querySelectorAll('.icon-chevron');
                childrenContainers.forEach((container) => {
                    if (allCollapsed) {
                        container.classList.add('hidden');
                    } else {
                        container.classList.remove('hidden');
                    }
                });
                chevrons.forEach((chevron) => {
                    if (allCollapsed) {
                        chevron.classList.remove('rotate-180');
                    } else {
                        chevron.classList.add('rotate-180');
                    }
                });
            });
        }
    }

    isInRange(value: number, min: number, max: number) {
        return min < value && value < max;
    }

    connectedCallback() {
        const element = document.querySelector('.prose');
        if (element) {
            element.addEventListener('animationend', () => {
                this.init();
            }, { once: true });
        } else {
            this.init();
        }
    }

    init() {
        this.tocEl = document.getElementById("toc-inner-wrapper");
        this.setupCollapsibleToggles();

        if (!this.tocEl) return;

        this.tocEl.addEventListener("click", this.handleAnchorClick, {
            capture: true,
        });

        this.activeIndicator = document.getElementById("active-indicator");

        this.tocEntries = Array.from(
            this.querySelectorAll<HTMLAnchorElement>("a[href^='#']")
        );

        if (this.tocEntries.length === 0) return;

        this.sections = new Array(this.tocEntries.length);
        this.headings = new Array(this.tocEntries.length);
        for (let i = 0; i < this.tocEntries.length; i++) {
            const id = decodeURIComponent(this.tocEntries[i].hash?.substring(1));
            const heading = document.getElementById(id);
            const section = heading?.parentElement;
            if (heading instanceof HTMLElement && section instanceof HTMLElement) {
                this.headings[i] = heading;
                this.sections[i] = section;
                this.headingIdxMap.set(id, i);
            }
        }
        this.active = new Array(this.tocEntries.length).fill(false);

        this.sections.forEach((section) => {
            if (section) this.observer.observe(section);
        });

        this.fallback();
        this.update();
    }

    disconnectedCallback() {
        this.sections.forEach((section) => {
            if (section) this.observer.unobserve(section);
        });
        this.observer.disconnect();
        this.tocEl?.removeEventListener("click", this.handleAnchorClick);
    }
}

if (!customElements.get("table-of-contents")) {
    customElements.define("table-of-contents", TableOfContents);
}
</script>