---
import BackToTop from "@components/control/BackToTop.astro";
import Footer from "@components/Footer.astro";
import Navbar from "@components/Navbar.astro";
import SideBar from "@components/widget/SideBar.astro";
import type { MarkdownHeading } from "astro";
import { Icon } from "astro-icon/components";
import ImageWrapper from "../components/misc/ImageWrapper.astro";
import TOC from "../components/widget/TOC.astro";
import { siteConfig } from "../config";
import {
	BANNER_HEIGHT,
	BANNER_HEIGHT_EXTEND,
	MAIN_PANEL_OVERLAPS_BANNER_HEIGHT,
} from "../constants/constants";
import Layout from "./Layout.astro";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	headings?: MarkdownHeading[];
}

const {
	title,
	banner,
	description,
	lang,
	setOGTypeArticle,
	headings = [],
} = Astro.props;

const hasBannerCredit =
	siteConfig.banner.enable && siteConfig.banner.credit.enable;
const hasBannerLink = !!siteConfig.banner.credit.url;

const mainPanelTop = siteConfig.banner.enable
	? `calc(${BANNER_HEIGHT}vh - ${MAIN_PANEL_OVERLAPS_BANNER_HEIGHT}rem)`
	: "5.5rem";

const hasHeadings = headings && headings.length > 0;
---

<Layout title={title} banner={banner} description={description} lang={lang} setOGTypeArticle={setOGTypeArticle}>

<!-- Navbar -->
<slot slot="head" name="head"></slot>
<div id="top-row" class="z-50 pointer-events-none relative transition-all duration-700 max-w-[var(--page-width)] px-0 md:px-4 mx-auto">
    <div id="navbar-wrapper" class="pointer-events-auto sticky top-0 transition-all">
        <Navbar></Navbar>
    </div>
</div>

<!-- Banner -->
{siteConfig.banner.enable && <div id="banner-wrapper" class={`absolute z-10 w-full transition duration-700 overflow-hidden`} style={`top: -${BANNER_HEIGHT_EXTEND}vh`}>
    <ImageWrapper id="banner" alt="Banner image of the blog" class:list={["object-cover h-full transition duration-700 opacity-0 scale-105"]}
                  src={siteConfig.banner.src} position={siteConfig.banner.position}
    >
    </ImageWrapper>
</div>}

<!-- Main content -->
<div class="absolute w-full z-30 pointer-events-none" style={`top: ${mainPanelTop}`}>
    <div class:list={[
        "relative mx-auto pointer-events-auto transition-all duration-500",
        hasHeadings ? "max-w-[var(--page-width)] 2xl:max-w-[88rem]" : "max-w-[var(--page-width)]"
    ]}>
        <div id="main-grid" class:list={[
            "transition duration-700 w-full left-0 right-0 grid mx-auto gap-4 px-0 md:px-4",
            hasHeadings
                ? "grid-cols-1 lg:grid-cols-[17.5rem_1fr] 2xl:grid-cols-[17.5rem_1fr_16.5rem]"
                : "grid-cols-1 lg:grid-cols-[17.5rem_1fr]"
        ]}>
            <!-- Banner image credit -->
            {hasBannerCredit && <a href={siteConfig.banner.credit.url} id="banner-credit" target="_blank" rel="noopener" aria-label="Visit image source"
                                   class:list={["group onload-animation transition-all absolute flex justify-center items-center rounded-full " +
                                   "px-3 right-4 -top-[3.25rem] bg-black/60 hover:bg-black/70 h-9", {"hover:pr-9 active:bg-black/80": hasBannerLink}]}
            >
                <Icon class="text-white/75 text-[1.25rem] mr-1" name="material-symbols:copyright-outline-rounded" ></Icon>
                <div class="text-white/75 text-xs">{siteConfig.banner.credit.text}</div>
                <Icon class:list={["transition absolute text-[oklch(0.75_0.14_var(--hue))] right-4 text-[0.75rem] opacity-0",
                    {"group-hover:opacity-100": hasBannerLink}]}
                      name="fa6-solid:arrow-up-right-from-square">
                </Icon>
            </a>}

            <!-- Left Sidebar -->
            <SideBar class="mb-4 row-start-2 lg:row-start-1 col-span-1 lg:max-w-[17.5rem] onload-animation" headings={headings}></SideBar>

            <!-- Main Content Area -->
            <main id="swup-container" class="transition-swup-fade col-span-1 overflow-hidden">
                <div id="content-wrapper" class="onload-animation">
                    <slot></slot>
                    <div class="footer col-span-1 onload-animation hidden lg:block">
                        <Footer></Footer>
                    </div>
                </div>
            </main>

            <!-- Right TOC Sidebar (2xl screens: integrated 3rd column card) -->
            {siteConfig.toc.enable && hasHeadings && (
                <div class="hidden 2xl:block col-span-1 onload-animation" style="animation-delay: 200ms">
                    <div id="toc-inner-wrapper" class="sticky top-20 card-base p-4 shadow-sm border border-black/5 dark:border-white/10 max-h-[calc(100vh-6rem)] overflow-y-auto hide-scrollbar">
                        <div class="font-bold text-sm text-neutral-900 dark:text-neutral-100 pb-2 mb-2 border-b border-neutral-200/60 dark:border-neutral-700/60 flex items-center gap-2">
                            <span class="w-2.5 h-2.5 rounded-full bg-[var(--primary)]"></span>
                            文章目录
                        </div>
                        <TOC headings={headings}></TOC>
                    </div>
                </div>
            )}

            <div class="footer col-span-full onload-animation block lg:hidden">
                <Footer></Footer>
            </div>
        </div>

        <BackToTop></BackToTop>
    </div>
</div>

<!-- #toc container fallback for Swup compatibility -->
<div id="toc" class="hidden"></div>
</Layout>
